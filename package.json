{
  "name": "louvorja-piano",
  "version": "1.14.3",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "desktopName": "louvorja-piano.desktop",
  "scripts": {
    "version:major": "npm version major -m \"chore: versão %s\"",
    "version:minor": "npm version minor -m \"chore: versão %s\"",
    "version:patch": "npm version patch -m \"chore: versão %s\"",
    "version:max": "npm run version:major",
    "version:min": "npm run version:minor",
    "version:bug": "npm run version:patch",
    "dev": "vite",
    "preview": "vite preview",
    "host": "vite --host",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "git:tag": "git tag -a \"v$npm_package_version\" -m \"Versão $npm_package_version\" && git push origin \"v$npm_package_version\"",
    "git:publish": "git push -u origin HEAD --follow-tags",
    "electron:dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173 && env -u ELECTRON_RUN_AS_NODE cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron . --class=louvorja-piano\"",
    "electron:preview": "vite build --base=./ && env -u ELECTRON_RUN_AS_NODE electron . --class=louvorja-piano",
    "electron:build": "vite build --base=./ && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fontsource-variable/plus-jakarta-sans": "^5.3.0",
    "@tabler/icons-webfont": "^3.45.0",
    "basic-ftp": "^6.0.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.6.4",
    "vuetify": "^4.1.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "npm-run-all2": "^9.0.2",
    "sass": "^1.101.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-tsc": "^3.3.5",
    "wait-on": "^9.0.10"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  },
  "overrides": {
    "@tabler/icons-webfont": {
      "svgtofont": "npm:noop2@2.0.0",
      "svg-path-commander": "npm:noop2@2.0.0",
      "@tabler/icons": "npm:noop2@2.0.0"
    }
  },
  "build": {
    "appId": "com.louvorja.piano",
    "productName": "LouvorJA - PIANO",
    "executableName": "louvorja-piano",
    "npmRebuild": false,
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/ico/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "AudioVideo",
      "icon": "build/icons",
      "executableName": "louvorja-piano",
      "syncDesktopName": true,
      "desktop": {
        "entry": {
          "Name": "LouvorJA - PIANO",
          "Comment": "LouvorJA - PIANO — aplicativo desktop para gerenciamento de culto",
          "Categories": "AudioVideo;",
          "StartupWMClass": "louvorja-piano"
        }
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "description": "LouvorJA - PIANO — aplicativo desktop para gerenciamento de culto",
  "author": "Kiki Solutions"
}
